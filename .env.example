# ──────────────────────────────────────────────
#  Telegram
# ──────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
ADMIN_TELEGRAM_ID=

# ──────────────────────────────────────────────
#  AI
# ──────────────────────────────────────────────
# OpenRouter — все запросы: GPT-4o (vision), GPT-4o-mini (текст), Gemini 2.0 Flash (голос)
OPENROUTER_API_KEY=

# ──────────────────────────────────────────────
#  Database (PostgreSQL)
# ──────────────────────────────────────────────
POSTGRES_USER=bot
POSTGRES_PASSWORD=change_me
POSTGRES_DB=foodbot

# ──────────────────────────────────────────────
#  Web server
# ──────────────────────────────────────────────
# Generate: openssl rand -hex 32
SESSION_SECRET=change_me

# ──────────────────────────────────────────────
#  Webhook
# ──────────────────────────────────────────────
# Public HTTPS URL — no trailing slash
WEBHOOK_URL=https://alxthecreatortg.ru
# Generate: openssl rand -hex 32
WEBHOOK_SECRET=change_me

# ──────────────────────────────────────────────
#  Timezone (for reminders)
# ──────────────────────────────────────────────
TZ=Europe/Moscow
